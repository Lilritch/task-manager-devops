DATABASE_URL=postgresql://taskuser:taskpass@postgres:5432/taskmanager
SECRET_KEY=change-me-to-a-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Optional GitHub sync settings. You can also type owner/repo in the dashboard.
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=

# Optional Slack slash command settings.
SLACK_SIGNING_SECRET=
SLACK_DEFAULT_USER_EMAIL=

# Only use this for local curl testing, never for real Slack traffic.
SLACK_ALLOW_UNSIGNED=false
